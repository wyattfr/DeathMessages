{
	"schemaVersion": 1,
	"id": "deathmessages",
	"version": "${version}",
	"name": "DeathMessages",
	"description": "A client-side mod that filters and suppresses repetitive death messages in Minecraft chat.",
	"authors": [
		"wyattfr_"
	],
	"contact": {
		"sources": "https://github.com/wyattfr/DeathMessages"
	},
	"license": "CC0-1.0",
	"icon": "assets/deathmessages/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"org.nightfall.deathmessages.client.DeathMessagesClient"
		]
	},
	"mixins": [
		{
			"config": "deathmessages.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.1",
		"minecraft": "26.1.2",
		"java": "*",
		"fabric-api": "*"
	}
}